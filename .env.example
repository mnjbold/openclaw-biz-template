# OpenClaw Business Template — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Core OpenClaw ──────────────────────────────────────────
OPENCLAW_DIR=/root/.openclaw

# ── Free Model Provider ────────────────────────────────────
# OpenCode Go — provides kimi-k2.5, glm-5, minimax-m2.5 (all free)
# Sign up: https://opencode.go
OPENCODE_GO_API_KEY=your_opencode_go_api_key_here

# ── Telegram ───────────────────────────────────────────────
# Create bot via @BotFather, get chat ID by messaging your bot then checking:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_numeric_chat_id_here

# ── MCP Integrations ───────────────────────────────────────
# Composio — Gmail, Drive, Calendar, LinkedIn, GitHub, Sheets
# Sign up: https://app.composio.dev
COMPOSIO_API_KEY=your_composio_api_key_here

# Supabase — database, storage, functions
# Get from: Project → Settings → API
SUPABASE_PROJECT_REF=your_project_ref_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── LinkedIn Recruiter (BeReach) ───────────────────────────
# BeReach — unofficial LinkedIn API (search, connect, message, inbox)
# Get key at: https://berea.ch/account
# Free tier: 30 connections/day, 100 messages/day, 350 profile visits/day
BEREACH_API_KEY=brc_YOUR_API_KEY_HERE

# ── Content Posting ────────────────────────────────────────
# PostIz — LinkedIn scheduling and publishing
# Get from: app.postiz.com → Settings → API
POSTIZ_API_KEY=your_postiz_api_key_here
POSTIZ_LINKEDIN_PERSONAL_CHANNEL_ID=your_personal_channel_id
POSTIZ_LINKEDIN_BRAND_CHANNEL_ID=your_brand_channel_id

# ── Claude / Anthropic (OPTIONAL — costs money) ────────────
# Only needed for claude-automation and claude-code-agent
# Models: claude-sonnet-4-6 ($3/$15), claude-haiku-4-5 ($0.80/$4), claude-opus-4-6 ($15/$75) per 1M tokens
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# ── Google Workspace (OPTIONAL) ────────────────────────────
# Set automatically by npx bb-workspace-setup
# Manual: path to service account JSON with domain-wide delegation
GOOGLE_SERVICE_ACCOUNT_PATH=/root/.openclaw/config/google-service-account.json
GOOGLE_WORKSPACE_DOMAIN=yourcompany.com
GOOGLE_WORKSPACE_ADMIN_EMAIL=admin@yourcompany.com

# ── Health Check Alerts ────────────────────────────────────
# Doctor.sh will send Telegram alerts when these are set
# (Same values as TELEGRAM_* above, duplicated for shell scripts)
# TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID already defined above

# ── Optional Integrations ──────────────────────────────────
GOOGLE_AI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
STRIPE_API_KEY=sk_live_your_stripe_key_here
RAILWAY_TOKEN=your_railway_token_here
GITHUB_TOKEN=ghp_your_github_token_here
